   "source": [
    "import numpy as np\n",
    "from autograd import Node, topo_sort"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e16c8f8a",
   "metadata": {},
   "outputs": [],
   "source": [
    "a = Node(np.ones((3, 3)), node_type=\"a\")\n",
    "b = Node(np.ones((3, 3)) * 2, node_type=\"b\")\n",
    "\n",
    "c = a + b\n",
    "c.node_type = \"c\"\n",
    "\n",
    "d = Node(np.ones((3, 3)) * 3, node_type=\"d\")\n",
    "\n",
    "e = c @ d\n",
    "e.node_type = \"e\"\n",
    "\n",
    "topo_sort(e)"
   ]
  }
 ],
